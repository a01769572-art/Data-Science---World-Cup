# Local environments and secrets
.env
.venv/
venv/

# Python caches and build output
__pycache__/
*.py[cod]
.pytest_cache/
.pytest-tmp/
pytest-cache-files-*/
.test-artifacts/
.ruff_cache/
*.egg-info/
build/
dist/

# Notebook and editor state
.ipynb_checkpoints/
.jupyter-runtime/
anaconda_projects/
.jupyter/

# Restricted or generated data
data/raw/restricted/
data/raw/odds/
data/raw/eloratings/
data/processed/

# Generated model artifacts
models/
artifacts/
# Source package for structural models is code, not a generated artifact.
!src/cdd_mundial/models/
*.joblib
*.pkl

# Authored CSV reference files and provenance manifests are intentionally allowed.
!data/external/**/*.csv
!data/metadata/**/*.json
