# Local environments and secrets
.env
.venv/
venv/

# Python caches and build output
__pycache__/
*.py[cod]
.pytest_cache/
.pytest-tmp/
pytest-cache-files-*/
.test-artifacts/
.ruff_cache/
*.egg-info/
build/
dist/

# Notebook and editor state
.ipynb_checkpoints/
.jupyter-runtime/
.jupyter_ystore.db
anaconda_projects/
.jupyter/

# Restricted or generated data
data/raw/restricted/
data/raw/odds/
data/raw/eloratings/
data/raw/regulations/
# Ignore processed contents (not the directory itself, so nested re-includes work).
data/processed/**
# The canonical append-only live calibration ledger is authoritative state that
# must be versioned for reproducibility (D-18); the dated live-training artifacts
# remain ignored runtime byproducts.
!data/processed/live/
!data/processed/live/calibration/
!data/processed/live/calibration/calibration_matches.parquet

# Generated model artifacts
models/
artifacts/
# Source package for structural models is code, not a generated artifact.
!src/cdd_mundial/models/
*.joblib
*.pkl

# Authored CSV reference files and provenance manifests are intentionally allowed.
!data/external/**/*.csv
!data/metadata/**/*.json

# Per-run dated live-training provenance is a runtime byproduct of the official
# daily pipeline (regenerated every official run), not a reviewed source artifact.
data/metadata/live_training_*.parquet.provenance.json

# Staging directories for in-progress snapshot publication are transient.
reports/snapshots/.stg-*
# Official append-only published snapshot bundles ARE versioned per D-12 (canonical
# snapshot data + rendered report committed before kickoff for auditability).
